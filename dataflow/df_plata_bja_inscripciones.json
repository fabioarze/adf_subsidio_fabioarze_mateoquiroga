{
	"name": "df_plata_bja_inscripciones",
	"properties": {
		"folder": {
			"name": "Silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "derivedColumn1"
				},
				{
					"name": "window1"
				},
				{
					"name": "filter1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          inscripcion_id as string,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as string,",
				"          fecha_inscripcion as string,",
				"          semana_gestacion as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronze',",
				"     tableName: 'bja_inscripciones',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source1",
				"source1 derive(inscripcion_id = trim(inscripcion_id),",
				"          ci_beneficiaria = trim(ci_beneficiaria),",
				"          establecimiento_id = trim(establecimiento_id),",
				"          fecha_inscripcion = trim(fecha_inscripcion),",
				"          semana_gestacion = trim(semana_gestacion),",
				"          estado = trim(estado)) ~> derivedColumn1",
				"derivedColumn1 window(over(establecimiento_id),",
				"     asc(establecimiento_id, true),",
				"     Fila = rowNumber()) ~> window1",
				"window1 filter(Fila == 1) ~> filter1",
				"filter1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'silver',",
				"     tableName: 'bja_inscripciones',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     truncate: true,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}