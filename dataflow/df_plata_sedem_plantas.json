{
	"name": "df_plata_sedem_plantas",
	"properties": {
		"folder": {
			"name": "Silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "trim"
				}
			],
			"scriptLines": [
				"source(output(",
				"          planta_id as string,",
				"          empresa_id as string,",
				"          nombre as string,",
				"          municipio as string,",
				"          departamento as string,",
				"          tipo as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronze',",
				"     tableName: 'sedem_plantas',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source1",
				"source1 derive(planta_id = trim(planta_id),",
				"          empresa_id = trim(empresa_id),",
				"          nombre = trim(nombre),",
				"          municipio = trim(municipio),",
				"          departamento = trim(departamento),",
				"          tipo = trim(tipo),",
				"          estado = trim(estado)) ~> trim",
				"trim sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'silver',",
				"     tableName: 'sedem_plantas',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}