{
	"name": "df_gold_hechos_pagos",
	"properties": {
		"folder": {
			"name": "Gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "ds_plata_bja_pagos",
						"type": "DatasetReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_oro_Hechos_Pagos",
						"type": "DatasetReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "aggregate1"
				}
			],
			"scriptLines": [
				"source(output(",
				"          pago_id as integer,",
				"          ci_beneficiaria as string,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          fecha_pago as date,",
				"          estado_pago as string,",
				"          canal_pago as string,",
				"          nro_comprobante as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> source1",
				"source1 aggregate(groupBy(pago_id),",
				"     ci_beneficiaria = first(ci_beneficiaria),",
				"          fecha_pago = first(fecha_pago),",
				"          concepto_pago = first(concepto_pago),",
				"          monto_bs = first(monto_bs),",
				"          estado_pago = first(estado_pago),",
				"          canal_pago = first(canal_pago)) ~> aggregate1",
				"aggregate1 sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          id_pago as integer,",
				"          ci_beneficiaria as string,",
				"          id_fecha as date,",
				"          concepto_pago as string,",
				"          monto_bs as decimal(10,2),",
				"          estado_pago as string,",
				"          canal_pago as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          ci_beneficiaria,",
				"          id_fecha = fecha_pago,",
				"          concepto_pago,",
				"          monto_bs,",
				"          estado_pago,",
				"          canal_pago",
				"     )) ~> sink1"
			]
		}
	}
}