{
	"name": "df_plata_ads_vehiculos",
	"properties": {
		"folder": {
			"name": "Silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "source1"
				}
			],
			"sinks": [
				{
					"linkedService": {
						"referenceName": "LS_Destino_DataWareH",
						"type": "LinkedServiceReference"
					},
					"name": "sink1"
				}
			],
			"transformations": [
				{
					"name": "trim"
				}
			],
			"scriptLines": [
				"source(output(",
				"          vehiculo_id as string,",
				"          transportista_id as string,",
				"          descripcion as string,",
				"          placa as string,",
				"          tipo as string,",
				"          capacidad_kg as string,",
				"          estado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'bronze',",
				"     tableName: 'vehiculos',",
				"     isolationLevel: 'READ_UNCOMMITTED') ~> source1",
				"source1 derive(vehiculo_id = trim(vehiculo_id),",
				"          transportista_id = trim(transportista_id),",
				"          descripcion = trim(descripcion),",
				"          placa = trim(placa),",
				"          tipo = trim(tipo),",
				"          capacidad_kg = trim(capacidad_kg),",
				"          estado = trim(estado)) ~> trim",
				"trim sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     format: 'table',",
				"     store: 'sqlserver',",
				"     schemaName: 'silver',",
				"     tableName: 'vehiculos',",
				"     insertable: true,",
				"     updateable: false,",
				"     deletable: false,",
				"     upsertable: false,",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sink1"
			]
		}
	}
}